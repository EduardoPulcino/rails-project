<%= render "shared/header" %>

<div class="container-grouped <%= action_name %>">
  <div class="title-decorations">
    <h1> Nossas decorações </h1>
  </div>
  <div class="hr-decoracao" style="margin: 0 auto;"></div>
  <p class="descricao" style="text-align:center;">
    Inspire-se em nossas decorações e escolha a sua favorita.
  </p>

  <%= render "search_form", search_url: grouped_decorations_path, search_term: @search %>

  <div class="decorations-content">
    <% if @search.present? && @filtered_ids&.empty? %>
      <p class="decorations-search-empty decorations-search-empty--public">Nenhuma decoração encontrada para "<%= @search %>"</p>
    <% end %>

    <% @event_types.each do |type| %>
      <% filtered_decorations = @filtered_ids ? type.decorations.select { |d| @filtered_ids.include?(d.id) } : type.decorations %>
      <% next if @search.present? && filtered_decorations.empty? %>

      <div class="title-link">
        <h2><%= type.name.upcase %></h2>
        <%= link_to "Ver mais", specific_decorations_path(type.id), class: "link", style: "margin-top: 40px;" %>
      </div>

      <div class="decorations">
        <% if filtered_decorations.empty? %>
          <div class="sem-decoraçao">
            <p> Sem decorações cadastradas </p>
          </div>
        <% else %>
          <% filtered_decorations.each do |decoration| %>
            <div class="decoration-card" tabindex="0">
              <%= link_to decoration_path(decoration) do %>
                <%= image_tag url_for(decoration.photos.first), alt: "Foto da decoração #{decoration.id}", class: "decoration-img" %>
              <% end %>

              <div class="decoration-overlay">
                <div class="decoration-title"><%= decoration.name %></div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<%= render "shared/footer"%>
